# AI Medical Chatbot - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real keys to GitHub!

# ============================================
# GROQ API (Recommended - Free & Fast)
# ============================================
# Get your free API key from: https://console.groq.com
# Steps:
# 1. Go to https://console.groq.com
# 2. Sign up with email
# 3. Create an API key in dashboard
# 4. Paste your key below
GROQ_API_KEY=your_groq_api_key_here

# Groq Models: mixtral-8x7b-32768, llama2-70b-4096, gemma-7b-it
GROQ_MODEL=mixtral-8x7b-32768

# ============================================
# OPENAI API (Optional - Paid)
# ============================================
# Get your API key from: https://openai.com/api/
# Add payment method to your OpenAI account
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# HUGGINGFACE (Optional - Free tier available)
# ============================================
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_MODEL=meta-llama/Llama-2-7b

# ============================================
# DATABASE (if using)
# ============================================
DATABASE_URL=sqlite:///medos.db

# ============================================
# DEPLOYMENT
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL (for API calls from frontend)
BACKEND_URL=http://localhost:7860

# ============================================
# MILVUS VECTOR DATABASE (if using)
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=medical_documents

# ============================================
# EMBEDDINGS
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real secrets to GitHub
# 2. Use .env file only for local development
# 3. Use GitHub Secrets or environment variables for production
# 4. Keep API keys private and rotate regularly
